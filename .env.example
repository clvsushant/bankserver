# Copy to .env for local development:
#   cp .env.example .env

# Leave unset for dev (enables /dev/* routes and raw-DDL auto-migrate).
# NODE_ENV=

PORT=4000
HOST=0.0.0.0

DATABASE_URL=./bankserver.sqlite

FRONTEND_ORIGIN=http://localhost:5174

WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5174
WEBAUTHN_RP_NAME=BankServer Demo

# 32+ chars so action/OTP tokens survive server restarts in dev.
ACTION_TOKEN_HMAC_KEY=dev-action-token-hmac-key-32chars!!
OTP_TOKEN_HMAC_KEY=dev-otp-token-hmac-key-32chars-min!!

# Accept code 000000 after requestOtp (dev/test only — never set in production).
OTP_STUB_BYPASS=true

SI_TICK_MS=60000
FD_TICK_MS=60000
SETTLE_TICK_MS=120000
