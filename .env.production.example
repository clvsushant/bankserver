# Copy to .env.production for production:
#   cp .env.production.example .env.production
# Then replace CHANGE_ME values with real secrets before deploying.

NODE_ENV=production

PORT=4000
HOST=0.0.0.0

DATABASE_URL=./bankserver.sqlite

FRONTEND_ORIGIN=https://your-frontend.example.com

WEBAUTHN_RP_ID=your-domain.example.com
WEBAUTHN_ORIGIN=https://your-frontend.example.com
WEBAUTHN_RP_NAME=BankServer

# Required: 32+ byte secrets shared across all backend nodes.
ACTION_TOKEN_HMAC_KEY=CHANGE_ME-action-token-hmac-key-32chars
OTP_TOKEN_HMAC_KEY=CHANGE_ME-otp-token-hmac-key-32chars-min

# Do NOT set OTP_STUB_BYPASS in production.

SI_TICK_MS=60000
FD_TICK_MS=60000
SETTLE_TICK_MS=120000
